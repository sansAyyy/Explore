{
  "ConnectionStrings": {
    "MessageCenterDatabase": "Host=localhost;Port=5432;Database=explore_message_center;Username=postgres;Password=postgres"
  },
  "RecipientDirectoryOptions": {
    "BaseUrl": "http://localhost:5230",
    "ProfilePathTemplate": "/api/users/{userId}/notification-profile",
    "Timeout": "00:00:10"
  },
  "JwtOptions": {
    "Issuer": "Explore",
    "Audience": "Explore.Clients",
    "SigningKey": "change-this-local-jwt-signing-key",
    "AccessTokenExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7
  },
  "RabbitMqOptions": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "LoggingOptions": {
    "ServiceName": "Explore.MessageCenterService",
    "Environment": "Default",
    "WriteToConsole": true,
    "WriteToFile": true,
    "FilePath": "logs/message-center-service-.log"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
