{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://admin.example.com",
      "https://app.example.com",
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "JwtOptions": {
    "Issuer": "Explore",
    "Audience": "Explore.Clients",
    "SigningKey": "change-this-local-jwt-signing-key",
    "AccessTokenExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7
  },
  "LoggingOptions": {
    "ServiceName": "Explore.Gateway.Api",
    "Environment": "Development",
    "WriteToConsole": true,
    "WriteToFile": true,
    "FilePath": "logs/gateway-.log"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "admin-identity-service-route": {
        "ClusterId": "admin-identity-cluster",
        "Match": {
          "Path": "/admin-identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/admin-identity"
          }
        ]
      },
      "message-center-service-route": {
        "ClusterId": "message-center-cluster",
        "Match": {
          "Path": "/message-center/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/message-center"
          }
        ]
      },
      "customer-account-service-route": {
        "ClusterId": "customer-account-cluster",
        "Match": {
          "Path": "/customer-account/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/customer-account"
          }
        ]
      }
    },
    "Clusters": {
      "admin-identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5229/"
          }
        }
      },
      "message-center-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5013/"
          }
        }
      },
      "customer-account-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5206/"
          }
        }
      }
    }
  }
}
